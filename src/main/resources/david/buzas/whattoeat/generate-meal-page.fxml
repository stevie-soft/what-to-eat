         </padding>
            <VBox prefHeight="463.0" prefWidth="1073.0">
               <VBox spacing="10" style="-fx-font-weight: bold; -fx-font-size: 18;">
                  <Label fx:id="soupNameLabel" />
                  <Label fx:id="mainCourseNameLabel" />
                  <Label fx:id="sideDishNameLabel" />
                  <Label fx:id="extraDishNameLabel" />
                  <Label fx:id="totalCostForintLabel" />
               </VBox>
               <Separator prefWidth="200.0">
                  <VBox.margin>
                     <Insets bottom="10.0" top="10.0" />
                  </VBox.margin>
               </Separator>
               <Button fx:id="generateButton" mnemonicParsing="false" onAction="#onGenerate" text="Új javaslat" />
            </VBox>
      </VBox>
